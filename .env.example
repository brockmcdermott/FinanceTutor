# -----------------------------------------------
# Supabase (required)
# -----------------------------------------------
# Get these from project settings -> API:
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# -----------------------------------------------
# Tutoring AI provider mode
# -----------------------------------------------
# true (default): deterministic tutoring feedback for demos/dev
# false: attempt real AI mode (requires OPENAI_API_KEY), otherwise falls back to mock
MOCK_AI=true

# -----------------------------------------------
# Optional OpenAI settings (only needed for real mode later)
# -----------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Override for proxy/self-hosted compatibility if needed.
OPENAI_BASE_URL=https://api.openai.com/v1
# Request timeout for real AI mode (milliseconds).
OPENAI_TIMEOUT_MS=15000

# Legacy compatibility flag (optional). Prefer MOCK_AI above.
# TUTORING_AI_MODE=mock
